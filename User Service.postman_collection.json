						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"tgest@gmail.com\",\n  \"mobileNumber\": \"9876543210\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"pincode\": \"400001\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/user/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"user",
								"register"
							]
						},
						"description": "Register with required details (no password needed). A verification email will be sent."
					},
					"response": [
						{
							"name": "Success Response",
							"originalRequest": {
								"method": "POST",
								"header": [],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"email\": \"user@example.com\",\n  \"mobileNumber\": \"9876543210\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"pincode\": \"400001\"\n}"
								},
								"url": {
									"raw": ""
								}
							},
							"status": "Created",
							"code": 201,
							"_postman_previewlanguage": "Text",
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"cookie": [],
							"body": "{\n  \"success\": true,\n  \"message\": \"Registration successful. Please check your email for verification.\",\n  \"data\": {\n    \"userId\": \"user-id\",\n    \"email\": \"user@example.com\"\n  }\n}"
						},
