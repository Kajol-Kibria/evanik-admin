							"name": "Error - Invalid Token",
							"originalRequest": {
								"method": "POST",
								"header": [],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"token\": \"invalid-token\",\n  \"password\": \"SecurePass123!\"\n}"
								},
								"url": {
									"raw": ""
								}
							},
							"status": "Bad Request",
							"code": 400,
							"_postman_previewlanguage": "Text",
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"cookie": [],
							"body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_TOKEN\",\n    \"message\": \"The verification token is invalid or has expired. Please request a new verification email.\"\n  }\n}"
