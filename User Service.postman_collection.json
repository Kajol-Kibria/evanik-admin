									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"cookie": [],
							"body": "{\n  \"success\": true,\n  \"message\": \"Email verified successfully. Please set your password to complete registration.\",\n  \"data\": {\n    \"token\": \"verification-token\"\n  }\n}"
